# Copy to .env.local for local dev. In production, set these in the Vercel
# dashboard under Project Settings > Environment Variables.

# --- Supabase (client-side, exposed in the bundle) -------------------------
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Single-user write gate (server-side only) -----------------------------
# Gates imports, settlements, edits, bankroll-event writes, and unit-size
# changes. Reads remain public.
AUTH_USERNAME=stack
AUTH_PASSWORD=54321

# OPTIONAL: HMAC secret that signs the session cookie.
# If unset, it's auto-derived from AUTH_PASSWORD (sha256). Set this explicitly
# only if you want session-cookie security to be independent of the password —
# e.g., when you rotate passwords frequently and don't want sessions to drop.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# AUTH_COOKIE_SECRET=optional-random-32-plus-character-string

# --- CLV / line-movement (server-side) -------------------------------------
# The Odds API key (Pinnacle via the eu region). https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here
# Service-role key for the cron to write odds_snapshots + CLV (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Shared secret Vercel sends to the cron as `Authorization: Bearer <CRON_SECRET>`.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=your_cron_secret_here

# --- Phase 11: DGS-PPH credentialed adapter (daemon only; betvegas23 disabled until an account exists) ---
# Credentials live ONLY in .env on the quant-edge-runner daemon host.
# NEVER commit values here — these are empty placeholders only.
# storageState files live under .auth/ (gitignored); populate via the manual auth-setup script.
SEVENSTACKS_USERNAME=
SEVENSTACKS_PASSWORD=
BETVEGAS23_USERNAME=
BETVEGAS23_PASSWORD=
